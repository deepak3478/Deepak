<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="base_length" value="0.6" />
    <xacro:property name="base_width"  value="0.4" />
    <xacro:property name="base_height" value="0.2" />
    <xacro:property name="wheel_radius" value="0.1" />
    <xacro:property name="wheel_length" value="0.05" />

    <!-- ================================================================
         BASE FOOTPRINT
    ================================================================ -->
    <link name="base_footprint" />

    <!-- ================================================================
         BASE LINK
    ================================================================ -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0" />
        </collision>
        <inertial>
            <mass value="5.0" />
            <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0" />
            <inertia
                ixx="${(1/12.0) * 5.0 * (base_width*base_width + base_height*base_height)}"
                ixy="0" ixz="0"
                iyy="${(1/12.0) * 5.0 * (base_length*base_length + base_height*base_height)}"
                iyz="0"
                izz="${(1/12.0) * 5.0 * (base_length*base_length + base_width*base_width)}" />
        </inertial>
    </link>

    <!-- ================================================================
         WHEEL MACRO  (visual + collision + inertial)
    ================================================================ -->
    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <material name="grey" />
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
            </collision>
            <inertial>
                <mass value="0.5" />
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <inertia
                    ixx="${(1/12.0) * 0.5 * (3*wheel_radius*wheel_radius + wheel_length*wheel_length)}"
                    ixy="0" ixz="0"
                    iyy="${(1/12.0) * 0.5 * (3*wheel_radius*wheel_radius + wheel_length*wheel_length)}"
                    iyz="0"
                    izz="${(1/2.0) * 0.5 * wheel_radius * wheel_radius}" />
            </inertial>
        </link>
    </xacro:macro>

    <xacro:wheel_link prefix="right" />
    <xacro:wheel_link prefix="left" />

    <!-- ================================================================
         CASTER WHEEL
    ================================================================ -->
    <link name="caster_wheel_link">
        <visual>
            <geometry>
                <sphere radius="${wheel_radius / 2.0}" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <sphere radius="${wheel_radius / 2.0}" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1" />
            <inertia
                ixx="${(2/5.0) * 0.1 * (wheel_radius/2.0) * (wheel_radius/2.0)}"
                ixy="0" ixz="0"
                iyy="${(2/5.0) * 0.1 * (wheel_radius/2.0) * (wheel_radius/2.0)}"
                iyz="0"
                izz="${(2/5.0) * 0.1 * (wheel_radius/2.0) * (wheel_radius/2.0)}" />
        </inertial>
    </link>

    <!-- ================================================================
         JOINTS  (same positions as your original)
    ================================================================ -->
    <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
    </joint>

    <joint name="base_right_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_link" />
        <origin xyz="${-base_length / 4.0} ${-(base_width + wheel_length) / 2.0} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <dynamics damping="0.01" friction="0.1" />
    </joint>

    <joint name="base_left_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_link" />
        <origin xyz="${-base_length / 4.0} ${(base_width + wheel_length) / 2.0} 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <dynamics damping="0.01" friction="0.1" />
    </joint>

    <joint name="base_caster_wheel_joint" type="fixed">
        <parent link="base_link" />
        <child link="caster_wheel_link" />
        <origin xyz="${base_length / 3.0} 0 ${-wheel_radius / 2.0}" rpy="0 0 0" />
    </joint>

    <!-- ================================================================
         ROS2_CONTROL  — hardware interface wiring
         Joint names match exactly: base_left_wheel_joint, base_right_wheel_joint
    ================================================================ -->
    <ros2_control name="my_robot" type="system">
        <hardware>
            <!-- For Gazebo simulation swap to:
                 <plugin>gazebo_ros2_control/GazeboSystem</plugin>
                 For real hardware, keep this and implement the plugin -->
            <plugin>mock_components/GenericSystem</plugin>
        </hardware>

        <joint name="base_left_wheel_joint">
            <command_interface name="velocity">
                <param name="min">-10</param>
                <param name="max"> 10</param>
            </command_interface>
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>

        <joint name="base_right_wheel_joint">
            <command_interface name="velocity">
                <param name="min">-10</param>
                <param name="max"> 10</param>
            </command_interface>
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>
    </ros2_control>

</robot>
